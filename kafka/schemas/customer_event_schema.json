{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CustomerActivityEvent",
  "type": "object",
  "required": [
    "event_id",
    "user_id",
    "event_type",
    "event_time",
    "source"
  ],
  "properties": {
    "event_id": {
      "type": "string"
    },
    "user_id": {
      "type": "string"
    },
    "session_id": {
      "type": "string"
    },
    "event_type": {
      "type": "string",
      "enum": [
        "user_login",
        "product_view",
        "cart_add",
        "checkout",
        "payment_success",
        "payment_failed"
      ]
    },
    "product_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "category": {
      "type": [
        "string",
        "null"
      ]
    },
    "price": {
      "type": [
        "number",
        "null"
      ]
    },
    "quantity": {
      "type": [
        "integer",
        "null"
      ]
    },
    "payment_method": {
      "type": [
        "string",
        "null"
      ]
    },
    "event_time": {
      "type": "string"
    },
    "source": {
      "type": "string"
    }
  }
}